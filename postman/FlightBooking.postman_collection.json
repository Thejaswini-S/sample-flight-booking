{
  "info": {
    "name": "Flight Booking API",
    "description": "End-to-end booking flow: register a flight, book seats, then verify overbooking (409), unknown flight (404), and validation (400). Each run uses a fresh random flight number so it is re-runnable against a live instance.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" }
  ],
  "item": [
    {
      "name": "Register flight (201)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('flight', 'PA' + Math.floor(Math.random() * 9000 + 1000));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('201 Created', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/flights", "host": [ "{{baseUrl}}" ], "path": [ "api", "v1", "flights" ] },
        "body": { "mode": "raw", "raw": "{\"flightNumber\":\"{{flight}}\",\"origin\":\"BLR\",\"destination\":\"DXB\",\"totalSeats\":5}" }
      }
    },
    {
      "name": "Book 3 seats (201)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('201 Created', () => pm.response.to.have.status(201));",
              "pm.test('has bookingId', () => pm.expect(pm.response.json().bookingId).to.be.a('string'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/bookings", "host": [ "{{baseUrl}}" ], "path": [ "api", "v1", "bookings" ] },
        "body": { "mode": "raw", "raw": "{\"flightNumber\":\"{{flight}}\",\"passengerName\":\"Thejaswini\",\"seats\":3}" }
      }
    },
    {
      "name": "Overbook -> 409",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('409 Conflict', () => pm.response.to.have.status(409));",
              "pm.test('errorCode FB-409-001', () => pm.expect(pm.response.json().errorCode).to.eql('FB-409-001'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/bookings", "host": [ "{{baseUrl}}" ], "path": [ "api", "v1", "bookings" ] },
        "body": { "mode": "raw", "raw": "{\"flightNumber\":\"{{flight}}\",\"passengerName\":\"Late\",\"seats\":3}" }
      }
    },
    {
      "name": "Unknown flight -> 404",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('404 Not Found', () => pm.response.to.have.status(404));",
              "pm.test('errorCode FB-404-001', () => pm.expect(pm.response.json().errorCode).to.eql('FB-404-001'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/bookings", "host": [ "{{baseUrl}}" ], "path": [ "api", "v1", "bookings" ] },
        "body": { "mode": "raw", "raw": "{\"flightNumber\":\"ZZ-9\",\"passengerName\":\"X\",\"seats\":1}" }
      }
    },
    {
      "name": "Invalid body -> 400",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
              "pm.test('errorCode FB-400-001', () => pm.expect(pm.response.json().errorCode).to.eql('FB-400-001'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/bookings", "host": [ "{{baseUrl}}" ], "path": [ "api", "v1", "bookings" ] },
        "body": { "mode": "raw", "raw": "{\"flightNumber\":\"\",\"passengerName\":\"\",\"seats\":0}" }
      }
    }
  ]
}
