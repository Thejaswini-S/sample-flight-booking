<?xml version="1.0" encoding="UTF-8"?>
<!--
  Centralized, rolling application logs.
  - Console + rolling file appenders.
  - Daily rolling with a 7-day retention (TTL), gzip-compressed history, and a total size cap.
  - Log directory comes from the `logging.file.path` property (see application.yml), default `logs`.
-->
<configuration>

    <springProperty name="LOG_PATH" source="logging.file.path" defaultValue="logs"/>
    <property name="LOG_FILE" value="${LOG_PATH}/flight-booking"/>
    <property name="PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <!-- Keep 7 days of history (7-day TTL) -->
            <maxHistory>7</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
